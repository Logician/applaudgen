def _camelcase(string):
    """ Convert string into camel case.

    Args:
        string: String to convert.

    Returns:
        string: Camel case string.

    """

    string = re.sub(r"^[\-_\.]", '', str(string))
    if not string:
        return string
    return (str(string[0]).lower()
            + re.sub(r"[\-_\.\s]([a-z])",
                    lambda matched: str(matched.group(1)).upper(),
                    string[1:]))

class ApplaudModel(BaseModel):
    model_config = ConfigDict(
        alias_generator=_camelcase,
        populate_by_name=True,
        # Allow extra fields so that unknown fields returned by the API do not cause validation to fail.
        extra='allow',
    )

